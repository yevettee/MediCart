# Firebase
FB_CRED=/path/to/serviceAccountKey.json
FB_DB_URL=https://<project>-default-rtdb.asia-southeast1.firebasedatabase.app
# AMR 네임스페이스(NS) — 보통 .env에 두지 않고 common/robot.env의 ROBOT_NAMESPACE에서 도출.
#   (override 필요 시에만 아래 주석 해제. SECONDARY 미지정 시 PRIMARY의 나머지로 자동: robot3↔robot6)
# PRIMARY_NS=robot6
# SECONDARY_NS=robot3
# 웹 인증/CORS
INTEL_PASSWORD=rokey1234
INTEL_AUTH_TOKEN=  # 랜덤 생성: python3 -c "import secrets;print(secrets.token_urlsafe(32))"
FRONTEND_ORIGIN=https://intel.thatshoon.com
COOKIE_SECURE=1
PORT=5000
# 맵 파일(있으면 서빙) — MediCart standalone: common/maps
MAP_PNG=/home/rokey/MediCart/common/maps/ward_map.png
MAP_YAML=/home/rokey/MediCart/common/maps/ward_map.yaml
